# Skopiuj poniższe linie do .env.local na komputerze w sieci firmowej (LAN).
# Wymagane: komputer z npm run dev musi widzieć host Subiekta (ping / curl).

SUBIEKT_API_BASE_URL=http://192.168.0.140:5080/api/v1
SUBIEKT_API_AUTH_MODE=none
SUBIEKT_API_HEALTH_PATH=/health
SUBIEKT_API_TIMEOUT_MS=15000

# Klucz API wyłączony u Ciebie — nie ustawiaj SUBIEKT_API_KEY.
# Gdy włączysz klucz na serwerze Subiekta:
# SUBIEKT_API_KEY=twoj-klucz
# SUBIEKT_API_AUTH_MODE=bearer
