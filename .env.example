NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=
# Domena zweryfikowana w Resend (DNS)
EMAIL_DOMAIN=projektorowo.pl
# Nadawca — Nazwa <adres@domena>; bez EMAIL_FROM użyje OnTime@EMAIL_DOMAIN
EMAIL_FROM_LOCAL=OnTime
EMAIL_FROM=System Dostaw <OnTime@projektorowo.pl>
# Opcjonalnie: testy bez wysyłki do handlowców (wszystko na ten adres)
# EMAIL_OVERRIDE_TO=tylko-na-czas-testow@example.com
CRON_SECRET=change-me-in-production
# Losowy sekret do hashowania kodów OTP resetu hasła (min. 32 znaki). Produkcja: wymagany.
# Wygeneruj: openssl rand -hex 32
PASSWORD_RESET_OTP_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Produkcja (serwer LAN Mikran) — APP_URL bez przebudowy po zmianie hosta:
# APP_URL=http://ontime.mikran.pl:3000
# NEXT_PUBLIC_APP_URL=http://ontime.mikran.pl:3000
# APP_SERVER_HOST=192.168.0.140
# APP_PORT=3000
# LAN_DEV_HOST=ontime.mikran.pl
# SERVER_ACTION_ALLOWED_ORIGINS=ontime.mikran.pl,ontime.mikran.pl:3000,192.168.0.140,192.168.0.140:3000
# Test z telefonu w Wi‑Fi (dev):
# NEXT_PUBLIC_APP_URL=http://192.168.x.x:3000
# LAN_DEV_HOST=192.168.x.x
# Gdy dev otwierasz z innego hosta/IP i Server Actions zwracają „unexpected response”:
# SERVER_ACTION_ALLOWED_ORIGINS=192.168.1.42,192.168.1.42:3000
# Dev: pełny dostęp admin bez logowania (na testach uprawnień ustaw false)
DEV_ADMIN_MODE=false

# Pierwsza konfiguracja serwera (Linux / LAN):
#   npm run server-setup
#   npm run server-setup -- --from-env .env.work --systemd --cron

# --- Subiekt (opcjonalnie, tylko w LAN) — patrz docs/integrations/subiekt.md ---
# Wzór na pracę: .env.subiekt.work.example
# SUBIEKT_API_BASE_URL=http://192.168.0.140:5080/api/v1
# SUBIEKT_API_AUTH_MODE=none
# SUBIEKT_API_KEY=
# SUBIEKT_API_USER=
# SUBIEKT_API_PASSWORD=
# SUBIEKT_API_KEY_HEADER=X-Api-Key
# SUBIEKT_API_HEALTH_PATH=/health
# SUBIEKT_API_TIMEOUT_MS=15000
