{
  "name": "system-dostaw-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lan-check": "bash scripts/lan-check.sh",
    "lint": "eslint",
    "lint:session": "eslint --no-cache $(grep -v '^#' scripts/eslint-session-paths.txt | tr '\\n' ' ')",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "verify:migrations": "tsx scripts/verify-recent-migrations.ts",
    "verify:auth-env": "tsx scripts/verify-auth-production-env.ts",
    "audit:admin-mutations": "tsx scripts/audit-admin-mutations.ts",
    "audit:service-role": "tsx scripts/audit-service-role.ts",
    "verify:deploy": "npm run verify:migrations && npm run verify:auth-env && npm run audit:admin-mutations && npm run audit:service-role",
    "migrate": "tsx scripts/migrate-from-csv.ts",
    "build-ustawienia": "tsx scripts/build-ustawienia-from-pdf.ts",
    "sync-intervals": "npm run build-ustawienia && tsx scripts/backfill-interval-raw.ts",
    "import-ustawienia": "npm run build-ustawienia && tsx scripts/migrate-from-csv.ts ./data",
    "build-polska": "tsx scripts/build-polska-from-pdf.ts",
    "build-zagranica": "tsx scripts/build-zagranica-from-pdf.ts",
    "build-import": "tsx scripts/build-import-from-pdf.ts",
    "import-polska": "npm run build-polska && tsx scripts/import-location-schedules.ts POLSKA",
    "import-zagranica": "npm run build-zagranica && tsx scripts/import-location-schedules.ts ZAGRANICA",
    "import-location-schedules-csv": "tsx scripts/import-location-schedules-from-csv.ts",
    "verify-location-schedules": "tsx scripts/verify-location-schedules-import.ts",
    "import-import": "npm run build-import && tsx scripts/import-location-schedules.ts IMPORT",
    "verify-intervals": "tsx scripts/verify-schedule-intervals.ts",
    "backfill-interval-raw": "tsx scripts/backfill-interval-raw.ts",
    "backfill-ustawienia": "tsx scripts/backfill-ustawienia-from-json.ts",
    "backfill-sales-ack-zrealizowane": "tsx scripts/backfill-sales-acknowledged-zrealizowane.ts",
    "import-stats-pdf": "tsx scripts/import-delivery-stats-from-pdf.ts",
    "import-stats-csv": "tsx scripts/import-delivery-stats-from-csv.ts",
    "import-historia": "tsx scripts/import-historia-from-csv.ts",
    "rebuild-schedules-from-historia": "tsx scripts/rebuild-schedules-from-historia.ts",
    "seed": "tsx scripts/seed-demo.ts",
    "setup-check": "tsx scripts/setup-check.ts",
    "verify-bug-reports": "tsx scripts/verify-bug-reports-migration.ts",
    "server-setup": "bash scripts/server-setup.sh",
    "install-cron": "bash scripts/install-cron.sh",
    "install-cron:win": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/install-cron.ps1",
    "install-service": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/install-windows-service.ps1",
    "service": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/service.ps1",
    "service:start": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/service.ps1 start -Probe",
    "service:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/service.ps1 stop",
    "service:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/service.ps1 restart -Probe",
    "nightly-deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/nightly-deploy.ps1",
    "db:migrate:sales-cancel": "tsx scripts/apply-sql-migration.ts supabase/migrations/018_sales_cancel_bundle.sql",
    "db:migrate:sales-request-note": "tsx scripts/apply-sql-migration.ts supabase/migrations/058_individual_orders_sales_request_note.sql",
    "verify-sales-request-note": "tsx scripts/verify-sales-request-note-migration.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "date-fns": "^4.4.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "happy-dom": "^20.10.2",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
