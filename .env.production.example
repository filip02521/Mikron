# Szablon produkcji Mikran — skopiuj wartości do .env.local na serwerze 192.168.0.140
#   cp .env.production.example .env.local   (uzupełnij klucze Supabase / Resend)
#
# Po zmianie NEXT_PUBLIC_APP_URL: npm run build && npm run start
#
# Site URL: http://ontime.mikran.pl:3000
#   Redirect URLs:
#     http://ontime.mikran.pl:3000/**
#     http://192.168.0.140:3000/**

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

RESEND_API_KEY=
EMAIL_DOMAIN=projektorowo.pl
EMAIL_FROM_LOCAL=OnTime
EMAIL_FROM=System Dostaw <OnTime@projektorowo.pl>
CRON_SECRET=change-me-in-production

# Kanoniczny adres = ten sam, który wpisują użytkownicy w przeglądarce.
# Aplikacja nasłuchuje na porcie 3000 (npm run start -H 0.0.0.0).
# Gdy dodacie reverse proxy na porcie 80, zmień na http://ontime.mikran.pl (bez :3000).
NEXT_PUBLIC_APP_URL=http://ontime.mikran.pl:3000

# Serwer fizyczny (dla whitelist Supabase i Server Actions)
APP_SERVER_HOST=192.168.0.140
APP_PORT=3000
LAN_DEV_HOST=ontime.mikran.pl
SERVER_ACTION_ALLOWED_ORIGINS=ontime.mikran.pl,ontime.mikran.pl:3000,192.168.0.140,192.168.0.140:3000

DEV_ADMIN_MODE=false

SUBIEKT_API_BASE_URL=http://192.168.0.140:5080/api/v1
SUBIEKT_API_AUTH_MODE=none
SUBIEKT_API_HEALTH_PATH=/health
SUBIEKT_API_TIMEOUT_MS=15000
